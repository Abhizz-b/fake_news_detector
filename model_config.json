{
  "providers": {
    "groq": {
      "name": "Groq",
      "type": "openai_compatible",
      "base_url": "https://api.groq.com/openai/v1",
      "api_key": "${GROQ_API_KEY:-}",
      "models": {
        "llama-3.3-70b-versatile": {
          "name": "Llama 3.3 70B Versatile",
          "type": "chat",
          "max_tokens": 8192,
          "supports_streaming": true
        },
        "llama-3.1-8b-instant": {
          "name": "Llama 3.1 8B Instant",
          "type": "chat",
          "max_tokens": 8192,
          "supports_streaming": true
        },
        "openai/gpt-oss-120b": {
          "name": "GPT-OSS 120B (via Groq)",
          "type": "chat",
          "max_tokens": 8192,
          "supports_streaming": true
        }
      }
    },
    "gemini": {
      "name": "Google Gemini",
      "type": "openai_compatible",
      "base_url": "https://generativelanguage.googleapis.com/v1beta/openai/",
      "api_key": "${GEMINI_API_KEY:-}",
      "models": {
        "gemini-embedding-001": {
          "name": "Gemini Embedding 001",
          "type": "embedding",
          "max_tokens": 2048,
          "dimensions": 768
        }
      }
    },
    "openai": {
      "name": "OpenAI",
      "type": "openai_compatible",
      "base_url": "https://api.openai.com/v1",
      "api_key": "${OPENAI_API_KEY:-}",
      "models": {
        "gpt-4": {
          "name": "GPT-4",
          "max_tokens": 8192,
          "supports_streaming": true,
          "supports_function_calling": true
        },
        "gpt-3.5-turbo": {
          "name": "GPT-3.5 Turbo",
          "max_tokens": 4096,
          "supports_streaming": true
        }
      }
    },
    "lmstudio": {
      "name": "LM Studio",
      "type": "openai_compatible",
      "base_url": "${LMSTUDIO_BASE_URL:-http://localhost:1234}",
      "api_key": "lm-studio",
      "models": {
        "jan-v1-4b": {
          "name": "Jan v1 4B",
          "type": "chat",
          "max_tokens": 4096,
          "supports_streaming": true
        },
        "gemma-3-270m-it": {
          "name": "Gemma 3 270M Instruct",
          "type": "chat",
          "max_tokens": 4096,
          "supports_streaming": true
        },
        "text-embedding-nomic-embed-text-v1.5": {
          "name": "Nomic Embed Text v1.5",
          "type": "embedding",
          "max_tokens": 8192,
          "dimensions": 768
        },
        "default": {
          "name": "Local Model",
          "type": "chat",
          "max_tokens": 4096,
          "supports_streaming": true
        }
      }
    },
    "local_api": {
      "name": "Local API Server",
      "type": "openai_compatible",
      "base_url": "http://localhost:8000/v1",
      "api_key": "EMPTY",
      "models": {
        "jan-v1-4b": {
          "name": "Jan v1 4B",
          "type": "chat",
          "max_tokens": 4096,
          "supports_streaming": true
        },
        "qwen/qwen3-4b-2507": {
          "name": "Qwen3 4B 2507",
          "type": "chat",
          "max_tokens": 4096,
          "supports_streaming": true
        },
        "text-embedding-nomic-embed-text-v1.5": {
          "name": "Nomic Embed Text v1.5",
          "type": "embedding",
          "max_tokens": 8192,
          "dimensions": 768
        }
      }
    },
    "custom_openai": {
      "name": "Custom OpenAI Compatible",
      "type": "openai_compatible",
      "base_url": "${CUSTOM_OPENAI_BASE_URL:-http://localhost:8000/v1}",
      "api_key": "${CUSTOM_OPENAI_API_KEY:-EMPTY}",
      "models": {
        "default": {
          "name": "Custom Model",
          "max_tokens": 4096,
          "supports_streaming": true
        }
      }
    }
  },
  "search_providers": {
    "duckduckgo": {
      "name": "DuckDuckGo",
      "type": "duckduckgo",
      "proxy": null,
      "timeout": 60,
      "max_results": 5,
      "enabled": true
    },
    "searxng": {
      "name": "SearXNG",
      "type": "searxng",
      "base_url": "${SEARXNG_BASE_URL:-http://host.docker.internal:8090}",
      "timeout": 30,
      "max_results": 20,
      "format": "json",
      "categories": "general"
    }
  },
  "defaults": {
    "llm_provider": "groq",
    "llm_model": "llama-3.3-70b-versatile",
    "embedding_provider": "gemini",
    "embedding_model": "gemini-embedding-001",
    "search_provider": "duckduckgo",
    "temperature": 0.0,
    "max_tokens": 2000,
    "output_language": "en",
    "evidence_display_multiplier": 2.5
  },
  "languages": {
    "auto": {
      "name": "Auto Detect",
      "code": "auto"
    },
    "en": {
      "name": "English",
      "code": "en"
    }
  }
}